{
  "name": "mofuri",
  "version": "0.1.0",
  "description": "Next-Gen Static Site Generator",
  "main": ".mofuri/cli/index.ts",
  "type": "module",
  "bin": {
    "mofuri": ".mofuri/cli/index.ts"
  },
  "imports": {
    "#core/*.ts": "./.mofuri/core/*.ts",
    "#core/*": "./.mofuri/core/*"
  },
  "workspaces": [
    ".mofuri/core"
  ],
  "dependencies": {
    "commander": "^12.0.0",
    "front-matter": "^4.0.2",
    "marked": "^12.0.0",
    "yaml": "^2.4.0",
    "mofuri-core": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "latest",
    "@types/bun": "latest"
  },
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}
